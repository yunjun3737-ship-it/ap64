            end
        end

        if FeatureStates["낙사 방지"] and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            if LocalPlayer.Character.HumanoidRootPart.Position.Y < -20 then
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(0,50,0)
            end
        end

    end)
end)
