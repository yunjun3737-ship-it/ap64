RunService.Heartbeat:Connect(function()
   pcall(function()
      if LocalPlayer.Character then
         local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
         local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
         
         -- 스피드 및 점프력 강제 고정 (안티 치트 프레임워크 우회 스태킹)
         if hum then
            if hum.WalkSpeed ~= _G.WalkSpeed then hum.WalkSpeed = _G.WalkSpeed end
            if hum.JumpPower ~= _G.JumpPower then hum.UseJumpPower = true; hum.JumpPower = _G.JumpPower end
            if hum.HipHeight ~= _G.HipHeight then hum.HipHeight = _G.HipHeight end
            if AntiSit and hum.Sit then hum.Sit = false end
         end
         
         -- 관성 제거 연산
         if NoInertia and root and hum and hum.MoveDirection.Magnitude == 0 then
            root.Velocity = Vector3.new(0, root.Velocity.Y, 0)
         end
         
         -- 벽 뚫기 가동
         if NoClip then
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
               if part:IsA("BasePart") then part.CanCollide = false end
            end
         end
      end
   end)
end)

