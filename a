            end

            if FeatureName == "자동 점프" and Value then
                task.spawn(function()
                    while FeatureStates["자동 점프"] do
                        task.wait(0.25)

                        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                            LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Jumping)
                        end
                    end
                end)
            end

            if FeatureName == "역중력" then
                workspace.Gravity = Value and -50 or 196.2
            end

            if FeatureName == "무중력" then
                workspace.Gravity = Value and 0 or 196.2
            end

            if FeatureName == "달 중력" then
                workspace.Gravity = Value and 35 or 196.2
            end

            if FeatureName == "캐릭터 투명화" then
                if LocalPlayer.Character then
                    for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
                        if v:IsA("BasePart") then
                            v.Transparency = Value and 0.6 or 0
                        end
                    end
                end
            end

            if FeatureName == "무한 줌" then
                if Value then
                    LocalPlayer.CameraMaxZoomDistance = 999999
                else
                    LocalPlayer.CameraMaxZoomDistance = 128
                end
            end

            if FeatureName == "미니 모드" then
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                    LocalPlayer.Character.Humanoid.BodyDepthScale.Value = Value and 0.5 or 1
                    LocalPlayer.Character.Humanoid.BodyWidthScale.Value = Value and 0.5 or 1
                    LocalPlayer.Character.Humanoid.BodyHeightScale.Value = Value and 0.5 or 1
                end
            end

            if FeatureName == "거대 캐릭터" then
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                    LocalPlayer.Character.Humanoid.BodyDepthScale.Value = Value and 2 or 1
                    LocalPlayer.Character.Humanoid.BodyWidthScale.Value = Value and 2 or 1
                    LocalPlayer.Character.Humanoid.BodyHeightScale.Value = Value and 2 or 1
                end
            end

            if FeatureName == "빠른 애니메이션" then
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                    for _, track in pairs(LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):GetPlayingAnimationTracks()) do
                        track:AdjustSpeed(Value and 2 or 1)
                    end
                end
            end

            if FeatureName == "느린 애니메이션" then
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                    for _, track in pairs(LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):GetPlayingAnimationTracks()) do
                        track:AdjustSpeed(Value and 0.5 or 1)
                    end
                end
            end

            if FeatureName == "네온 모드" and Value then
                for _, v in pairs(workspace:GetDescendants()) do
                    pcall(function()
                        if v:IsA("BasePart") then
                            v.Material = Enum.Material.Neon
                        end
                    end)
                end
            end

            if FeatureName == "블러 모드" then
                if Value then
                    local blur = Instance.new("BlurEffect")
                    blur.Name = "PacaBlur"
                    blur.Size = 20
                    blur.Parent = Lighting
                else
                    if Lighting:FindFirstChild("PacaBlur") then
                        Lighting.PacaBlur:Destroy()
                    end
                end
            end

            if FeatureName == "플래시 모드" and Value then
                task.spawn(function()
                    while FeatureStates["플래시 모드"] do
                        task.wait(0.1)
                        Lighting.Brightness = math.random(1,10)
                    end
                end)
            end

            if FeatureName == "랜덤 밝기" and Value then
                task.spawn(function()
                    while FeatureStates["랜덤 밝기"] do
                        task.wait(0.5)
                        Lighting.ClockTime = math.random(0,24)
                    end
                end)
            end

            if FeatureName == "자동 리셋" and Value then
                task.spawn(function()
                    while FeatureStates["자동 리셋"] do
                        task.wait(10)

                        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                            LocalPlayer.Character:FindFirstChildOfClass("Humanoid").Health = 0
                        end
                    end
                end)
            end
        end
    })
end

