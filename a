            Lighting.ClockTime = math.random(0,24)
        end

        if FeatureStates["카메라 흔들림"] then
            workspace.CurrentCamera.CFrame *= CFrame.new(
                math.random(-1,1)/10,
                math.random(-1,1)/10,
                0
            )
        end

        if FeatureStates["자동 회전"] and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame *= CFrame.Angles(0, math.rad(2), 0)
        end

        if FeatureStates["랜덤 점프"] and math.random(1,50) == 1 then
