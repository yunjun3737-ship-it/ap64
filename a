RunService.RenderStepped:Connect(function()

    pcall(function()

        if SpinBot and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame *= CFrame.Angles(0, math.rad(SpinSpeed), 0)
        end

        if AutoRotate and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame *= CFrame.Angles(0, math.rad(2), 0)
        end

        if HeadSpin and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") then
            LocalPlayer.Character.Head.CFrame *= CFrame.Angles(0, math.rad(15), 0)
        end

        if CameraShake then
            workspace.CurrentCamera.CFrame *= CFrame.new(
                math.random(-1,1)/15,
                math.random(-1,1)/15,
                0
            )
        end

        if RainbowLighting then
            Lighting.Ambient = Color3.fromHSV(tick()%5/5,1,1)
        end

        if RandomBrightness then
            Lighting.ClockTime = math.random(0,24)
        end

        if FlashMode then
            Lighting.Brightness = math.random(1,10)
        end

        if AntiVoid and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            if LocalPlayer.Character.HumanoidRootPart.Position.Y < -25 then
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(0,50,0)
            end
        end

        if RainbowCharacter and LocalPlayer.Character then
            for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.Color = Color3.fromHSV(tick()%5/5,1,1)
                end
            end
        end

        if AutoSit and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid").Sit = true
        end

        if AutoJump and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Jumping)
        end

        if FakeLag then
            task.wait(math.random(0.05,0.2))
        end

        if FastAnim and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            for _, track in pairs(LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):GetPlayingAnimationTracks()) do
                track:AdjustSpeed(2)
            end
        end

        if SlowAnim and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            for _, track in pairs(LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):GetPlayingAnimationTracks()) do
                track:AdjustSpeed(0.5)
            end
        end

    end)

end)
