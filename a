        end

        if FeatureStates["머리 회전"] and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") then
            LocalPlayer.Character.Head.CFrame *= CFrame.Angles(0, math.rad(15), 0)
        end

        if FeatureStates["무지개 조명"] then
            Lighting.Ambient = Color3.fromHSV(tick()%5/5,1,1)
        end

