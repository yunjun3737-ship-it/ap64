local CameraTab = Window:CreateTab("카메라", 4483362458)

local ThirdPerson = false
local ThirdPersonDistance = 25

CameraTab:CreateToggle({
    Name = "3인칭 모드",
    CurrentValue = false,
    Flag = "ThirdPersonToggle",
    Callback = function(Value)
        ThirdPerson = Value

        if Value then
            LocalPlayer.CameraMode = Enum.CameraMode.Classic

            LocalPlayer.CameraMinZoomDistance = ThirdPersonDistance
            LocalPlayer.CameraMaxZoomDistance = 999999
        else
            LocalPlayer.CameraMode = Enum.CameraMode.LockFirstPerson

            LocalPlayer.CameraMinZoomDistance = 0
            LocalPlayer.CameraMaxZoomDistance = 0
        end
    end
})

CameraTab:CreateInput({
    Name = "3인칭 거리",
    PlaceholderText = "기본값: 25",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        local num = tonumber(Text)

        if num then
            ThirdPersonDistance = num

            if ThirdPerson then
                LocalPlayer.CameraMinZoomDistance = num
            end
        end
    end
})
